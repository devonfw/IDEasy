<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<AnchorPane
  xmlns="http://javafx.com/javafx"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.devonfw.ide.gui.console.ConsoleController"
  prefWidth="Infinity"
  style="-fx-background-color: #FFFFF; -fx-border-color: #cccccc; -fx-border-width: 1;"
  AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
  AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
  fx:id="consoleRoot"
>

  <VBox spacing="5" minWidth="-Infinity" style="-fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;" AnchorPane.topAnchor="0"
    AnchorPane.bottomAnchor="0"
    AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
    <padding>
      <Insets top="5" right="5" bottom="5" left="5"/>
    </padding>

    <HBox spacing="10" style="-fx-padding: 5;" alignment="CENTER_LEFT">
      <Label text="Console" style="-fx-font-weight: bold; -fx-font-size: 12;" HBox.hgrow="ALWAYS"/>
      <Separator orientation="VERTICAL" style="-fx-padding: 0;"/>

      <Button fx:id="clearButton" text="Clear" prefWidth="60" style="-fx-font-size: 11;"/>
      <Button fx:id="scrollToBottomButton" text="Scroll to Bottom" prefWidth="120" style="-fx-font-size: 11;"/>

      <Region HBox.hgrow="ALWAYS"/>

      <CheckBox fx:id="autoScrollCheckBox" text="Auto-scroll" selected="true" style="-fx-font-size: 11;"/>
    </HBox>

    <Separator/>

    <ScrollPane fx:id="outputScrollPane" fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS">
      <TextArea fx:id="consoleOutput"
        wrapText="true"
        editable="false"
        style="-fx-font-family: 'Courier New'; -fx-font-size: 11; -fx-control-inner-background: #f5f5f5;"/>
    </ScrollPane>

    <HBox spacing="10" style="-fx-padding: 3; -fx-border-color: #e0e0e0; -fx-border-width: 1 0 0 0;">
      <Label fx:id="statusLabel" text="Ready" style="-fx-font-size: 10; -fx-text-fill: #666666;"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Label fx:id="lineCountLabel" text="Lines: 0" style="-fx-font-size: 10; -fx-text-fill: #666666;"/>
    </HBox>
  </VBox>
</AnchorPane>
