<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/25.0.0" xmlns:fx="http://javafx.com/fxml/1">
  <top>
    <VBox style="-fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;">
      <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="40.0"/>
      </padding>
      <children>
        <HBox spacing="10.0" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 12;">
          <children>
            <Label text="Enable" prefWidth="40.0"/>
            <Label text="Tool" prefWidth="120.0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Label text="Edition" prefWidth="130.0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            <Label text="Version" prefWidth="130.0" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
          </children>
        </HBox>
      </children>
    </VBox>
  </top>
  <center>
    <VBox spacing="0" maxHeight="1.7976931348623157E308">
      <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
      </padding>
      <children>
        <TreeView fx:id="toolsTree" style="-fx-font-size: 10;"
          VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"/>
      </children>
    </VBox>
  </center>
  <bottom>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
      <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
      </padding>
      <children>
        <Button fx:id="cancelButton" text="%button.cancel" onAction="#onCancel"/>
        <Button fx:id="previewButton" text="%button.preview" onAction="#onPreview"/>
        <Button fx:id="saveButton" text="%button.save" onAction="#onSave"/>
      </children>
    </HBox>
  </bottom>
</BorderPane>

