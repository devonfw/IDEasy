<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="515.0" prefWidth="817.0"
  xmlns="http://javafx.com/javafx/25.0.0"
  xmlns:fx="http://javafx.com/fxml/1">
  <left>
    <VBox prefHeight="428.0" prefWidth="181.0" spacing="4.0" stylesheets="@style/navigation.css" BorderPane.alignment="CENTER">
      <children>
        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
          <VBox.margin>
            <Insets bottom="10.0"/>
          </VBox.margin>
          <children>
            <!-- Wrap logo in a StackPane so we can overlay a circular upgrade indicator in the top-right corner -->
            <StackPane>
              <children>
                <ImageView fx:id="logoImage" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/logo.png"/>
                  </image>
                </ImageView>
                <!-- small circular status indicator, initially hidden -->
                <Circle fx:id="upgradeIndicator" radius="7.0" fill="#FFC107" stroke="#B58900" strokeWidth="1.0" visible="false" pickOnBounds="true"
                  StackPane.alignment="TOP_RIGHT" translateX="9.0" translateY="-5.0">
                  <StackPane.margin>
                    <Insets top="6.0" right="6.0"/>
                  </StackPane.margin>
                </Circle>
              </children>
              <!-- alignment set per-child using StackPane.alignment on the indicator -->
            </StackPane>
          </children>
        </HBox>
        <VBox maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelProject" maxWidth="1.7976931348623157E308" text="%label.project"/>
            <ComboBox fx:id="selectedProject" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseProject" styleClass="chooseProject"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
        <VBox layoutX="20.0" layoutY="245.0" maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelWorkspace" maxWidth="1.7976931348623157E308" text="%label.workspace"/>
            <ComboBox fx:id="selectedWorkspace" disable="true" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseWorkspace" styleClass="chooseProject" VBox.vgrow="ALWAYS"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
        <!-- Language selector -->
        <VBox maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelLanguage" maxWidth="1.7976931348623157E308" text="%label.language"/>
            <ComboBox fx:id="selectedLanguage" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseLanguage" styleClass="chooseProject"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
      </children>
      <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
      </padding>
    </VBox>
  </left>
  <center>
    <VBox BorderPane.alignment="CENTER">
      <children>
        <!-- Project header: updated by controller when selectedProject changes -->
        <Label fx:id="projectHeaderLabel" maxWidth="1.7976931348623157E308"
          style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #333333;"
          text="">
          <VBox.margin>
            <Insets left="30.0" top="24.0" right="30.0"/>
          </VBox.margin>
        </Label>
        <GridPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" hgap="32.0" vgap="24.0" VBox.vgrow="ALWAYS">
          <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
          </columnConstraints>
          <padding>
            <Insets top="12.0" right="30.0" bottom="24.0" left="30.0"/>
          </padding>
          <children>
            <!-- Android Studio -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
              stylesheets="@style/center.css"
              styleClass="ideElement"
              VBox.vgrow="ALWAYS"
              alignment="CENTER"
              spacing="10.0"
              style="-fx-background-color: #E0E3EA; -fx-background-radius: 16; -fx-border-color: #C8CCD4; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 24 20 20 20;"
            >
              <children>
                <ImageView fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/as.png"/>
                  </image>
                </ImageView>
                <Label styleClass="ideTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;" text="Android Studio"/>
                <Button fx:id="androidStudioOpen" disable="true" mnemonicParsing="false" onAction="#openAndroidStudio" styleClass="launchButton"
                  style="-fx-padding: 9 28 9 28; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8;"
                  text="%button.open">
                  <VBox.margin>
                    <Insets top="6.0"/>
                  </VBox.margin>
                </Button>
              </children>
            </VBox>
            <!-- Eclipse -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
              styleClass="ideElement"
              stylesheets="@style/center.css"
              VBox.vgrow="ALWAYS"
              alignment="CENTER"
              spacing="10.0"
              style="-fx-background-color: #E0E3EA; -fx-background-radius: 16; -fx-border-color: #C8CCD4; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 24 20 20 20;"
            >
              <children>
                <ImageView fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/eclipse.png"/>
                  </image>
                </ImageView>
                <Label styleClass="ideTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;" text="Eclipse"/>
                <Button fx:id="eclipseOpen" disable="true" mnemonicParsing="false" onAction="#openEclipse" styleClass="launchButton"
                  style="-fx-padding: 9 28 9 28; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8;"
                  text="%button.open">
                  <VBox.margin>
                    <Insets top="6.0"/>
                  </VBox.margin>
                </Button>
              </children>
            </VBox>
            <!-- Intellij -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1"
              styleClass="ideElement"
              stylesheets="@style/center.css"
              VBox.vgrow="ALWAYS"
              alignment="CENTER"
              spacing="10.0"
              style="-fx-background-color: #E0E3EA; -fx-background-radius: 16; -fx-border-color: #C8CCD4; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 24 20 20 20;"
            >
              <children>
                <ImageView fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/intellij.png"/>
                  </image>
                </ImageView>
                <Label styleClass="ideTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;" text="Intellij"/>
                <Button fx:id="intellijOpen" disable="true" mnemonicParsing="false" onAction="#openIntellij" styleClass="launchButton"
                  style="-fx-padding: 9 28 9 28; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8;"
                  text="%button.open">
                  <VBox.margin>
                    <Insets top="6.0"/>
                  </VBox.margin>
                </Button>
              </children>
            </VBox>
            <!-- VsCode -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1"
              styleClass="ideElement"
              stylesheets="@style/center.css"
              VBox.vgrow="ALWAYS"
              alignment="CENTER"
              spacing="10.0"
              style="-fx-background-color: #E0E3EA; -fx-background-radius: 16; -fx-border-color: #C8CCD4; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 24 20 20 20;"
            >
              <children>
                <ImageView fitHeight="96.0" fitWidth="96.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/vscode.png"/>
                  </image>
                </ImageView>
                <Label styleClass="ideTitle" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C2C2C;" text="VS Code"/>
                <Button fx:id="vsCodeOpen" disable="true" mnemonicParsing="false" onAction="#openVsCode" styleClass="launchButton"
                  style="-fx-padding: 9 28 9 28; -fx-font-size: 14px; -fx-background-radius: 8; -fx-border-radius: 8;"
                  text="%button.open">
                  <VBox.margin>
                    <Insets top="6.0"/>
                  </VBox.margin>
                </Button>
              </children>
            </VBox>
            <!-- Update Card -->
            <HBox GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2"
              spacing="20.0"
              styleClass="ideElement"
              stylesheets="@style/center.css"
              HBox.hgrow="ALWAYS"
              alignment="CENTER_LEFT"
              style="-fx-background-color: #E0E3EA; -fx-background-radius: 16; -fx-border-color: #C8CCD4; -fx-border-width: 1; -fx-border-radius: 16; -fx-padding: 14 20 14 20;"
            >
              <children>
                <ImageView fitHeight="48.0" fitWidth="48.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/update.png"/>
                  </image>
                  <HBox.margin>
                    <Insets left="6.0"/>
                  </HBox.margin>
                </ImageView>
                <Label fx:id="updateStatusLabel" style="-fx-font-size: 15px; -fx-font-weight: 600; -fx-text-fill: #2C2C2C;"
                  text="%status.update.selectProject"/>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                  <children>
                    <Button fx:id="updateButton" mnemonicParsing="false" text="%button.update" onAction="#onUpdateClicked"
                      styleClass="launchButton"
                      style="-fx-padding: 8 24 8 24; -fx-font-size: 13px; -fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 8; -fx-border-radius: 8;">
                    </Button>
                  </children>
                </HBox>
              </children>
            </HBox>
          </children>
        </GridPane>
      </children>
    </VBox>
  </center>
</BorderPane>
