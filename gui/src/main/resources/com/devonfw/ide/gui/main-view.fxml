<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import java.lang.Double?>
<BorderPane fx:id="rootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" prefHeight="515.0" prefWidth="817.0"
  xmlns="http://javafx.com/javafx/25.0.0"
  xmlns:fx="http://javafx.com/fxml/1">
  <top>
    <HBox alignment="CENTER_RIGHT" spacing="8.0" BorderPane.alignment="CENTER">
      <children>
        <!-- Upgrade status replaced by indicator; UpgradeController manages status and dialog -->
        <Label fx:id="updateStatusLabel" text="%status.update.selectProject"/>
        <Button fx:id="updateButton" mnemonicParsing="false" text="%button.update" onAction="#onUpdateClicked"/>
      </children>
      <padding>
        <Insets right="10.0" top="6.0" bottom="6.0"/>
      </padding>
    </HBox>
  </top>
  <left>
    <VBox prefHeight="428.0" prefWidth="181.0" spacing="4.0" stylesheets="@style/navigation.css" BorderPane.alignment="CENTER">
      <children>
        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
          <VBox.margin>
            <Insets bottom="10.0"/>
          </VBox.margin>
          <children>
            <!-- Wrap logo in a StackPane so we can overlay a circular upgrade indicator in the top-right corner -->
            <StackPane>
              <children>
                <ImageView fx:id="logoImage" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/logo.png"/>
                  </image>
                </ImageView>
                <!-- small circular status indicator, initially hidden -->
                <Circle fx:id="upgradeIndicator" radius="7.0" fill="#FFC107" stroke="#B58900" strokeWidth="1.0" visible="false" pickOnBounds="true"
                  StackPane.alignment="TOP_RIGHT" translateX="9.0" translateY="-5.0">
                  <StackPane.margin>
                    <Insets top="6.0" right="6.0"/>
                  </StackPane.margin>
                </Circle>
              </children>
              <!-- alignment set per-child using StackPane.alignment on the indicator -->
            </StackPane>
          </children>
        </HBox>
        <VBox maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelProject" maxWidth="1.7976931348623157E308" text="%label.project"/>
            <ComboBox fx:id="selectedProject" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseProject" styleClass="chooseProject"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
        <VBox layoutX="20.0" layoutY="245.0" maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelWorkspace" maxWidth="1.7976931348623157E308" text="%label.workspace"/>
            <ComboBox fx:id="selectedWorkspace" disable="true" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseWorkspace" styleClass="chooseProject" VBox.vgrow="ALWAYS"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
        <!-- Language selector -->
        <VBox maxHeight="-Infinity" prefWidth="100.0" styleClass="sideNavigationElement">
          <children>
            <Label fx:id="labelLanguage" maxWidth="1.7976931348623157E308" text="%label.language"/>
            <ComboBox fx:id="selectedLanguage" maxWidth="1.7976931348623157E308" minWidth="-Infinity" prefHeight="40.0" prefWidth="150.0"
              promptText="%prompt.chooseLanguage" styleClass="chooseProject"/>
          </children>
          <padding>
            <Insets left="8.0" right="8.0"/>
          </padding>
        </VBox>
      </children>
      <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
      </padding>
    </VBox>
  </left>
  <center>
    <StackPane prefHeight="150.0" BorderPane.alignment="CENTER">
      <fx:define>
        <Double fx:id="buttonContainerHeight" fx:value="80.0"/>
        <Double fx:id="buttonContainerWidth" fx:value="150.0"/>
      </fx:define>
      <children>
        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="231.0" spacing="12.0">
          <children>
            <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="204.0" prefHeight="100.0" prefWidth="150.0" spacing="20.0" stylesheets="@style/center.css"
              styleClass="ideElement">
              <children>
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/as.png"/>
                  </image>
                  <HBox.margin>
                    <Insets bottom="10.0" left="10.0" top="10.0"/>
                  </HBox.margin>
                </ImageView>
                <Label prefHeight="30.0" prefWidth="190.0" styleClass="ideTitle" text="Android-Studio"/>
                <HBox alignment="CENTER_RIGHT" prefHeight="$buttonContainerHeight" prefWidth="$buttonContainerWidth" minWidth="$buttonContainerWidth"
                  spacing="10.0" HBox.hgrow="ALWAYS">
                  <children>
                    <Button fx:id="androidStudioOpen" disable="true" mnemonicParsing="false" onAction="#openAndroidStudio" styleClass="launchButton"
                      text="%button.open">
                      <HBox.margin>
                        <Insets right="20.0"/>
                      </HBox.margin>
                    </Button>
                  </children>
                </HBox>
              </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="120.0" prefHeight="100.0" prefWidth="150.0" spacing="20.0" styleClass="ideElement"
              stylesheets="@style/center.css">
              <children>
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/eclipse.png"/>
                  </image>
                  <HBox.margin>
                    <Insets bottom="10.0" left="10.0" top="10.0"/>
                  </HBox.margin>
                </ImageView>
                <Label prefHeight="30.0" prefWidth="114.0" styleClass="ideTitle" text="Eclipse"/>
                <HBox alignment="CENTER_RIGHT" prefHeight="$buttonContainerHeight" prefWidth="$buttonContainerWidth" minWidth="$buttonContainerWidth"
                  HBox.hgrow="ALWAYS">
                  <children>
                    <Button fx:id="eclipseOpen" disable="true" mnemonicParsing="false" onAction="#openEclipse" styleClass="launchButton" text="%button.open">
                      <HBox.margin>
                        <Insets right="20.0"/>
                      </HBox.margin>
                    </Button>
                  </children>
                </HBox>
              </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="20.0" prefHeight="100.0" prefWidth="150.0" spacing="20.0" styleClass="ideElement"
              stylesheets="@style/center.css">
              <children>
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/intellij.png"/>
                  </image>
                  <HBox.margin>
                    <Insets bottom="10.0" left="10.0" top="10.0"/>
                  </HBox.margin>
                </ImageView>
                <Label prefHeight="30.0" prefWidth="100.0" styleClass="ideTitle" text="Intellij"/>
                <HBox alignment="CENTER_RIGHT" prefHeight="$buttonContainerHeight" prefWidth="$buttonContainerWidth" minWidth="$buttonContainerWidth"
                  spacing="10.0" HBox.hgrow="ALWAYS">
                  <children>
                    <Button fx:id="intellijOpen" disable="true" mnemonicParsing="false" onAction="#openIntellij" styleClass="launchButton" text="%button.open">
                      <HBox.margin>
                        <Insets right="20.0"/>
                      </HBox.margin>
                    </Button>
                  </children>
                </HBox>
              </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="150.0" spacing="20.0" styleClass="ideElement" stylesheets="@style/center.css">
              <children>
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                    <Image url="@assets/vscode.png"/>
                  </image>
                  <HBox.margin>
                    <Insets bottom="10.0" left="10.0" top="10.0"/>
                  </HBox.margin>
                </ImageView>
                <Label prefHeight="30.0" prefWidth="114.0" styleClass="ideTitle" text="VS Code"/>
                <HBox alignment="CENTER_RIGHT" prefHeight="$buttonContainerHeight" prefWidth="$buttonContainerWidth" minWidth="$buttonContainerWidth"
                  spacing="10.0" HBox.hgrow="ALWAYS">
                  <children>
                    <Button fx:id="vsCodeOpen" disable="true" mnemonicParsing="false" onAction="#openVsCode" styleClass="launchButton" text="%button.open">
                      <HBox.margin>
                        <Insets right="20.0"/>
                      </HBox.margin>
                    </Button>
                  </children>
                </HBox>
              </children>
            </HBox>
          </children>
          <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
          </padding>
        </VBox>
      </children>
    </StackPane>
  </center>
</BorderPane>
